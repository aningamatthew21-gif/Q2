# MIDSA Quote App — backend environment variables
# Copy this file to `backend/.env` and replace every <PLACEHOLDER>.
# Never commit the real `.env` — it is excluded by .gitignore.
#
# Generate strong JWT secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# ISO/IEC 27001 A.5.17 (Authentication information) compliance:
# - JWT_SECRET must be ≥ 32 chars of high-entropy random
# - DB password ≥ 12 chars, mixed case + digit + symbol
# - Rotate quarterly OR immediately on suspected exposure

# ──────────────────────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────────────────────
PORT="3001"
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"             # "development" | "production"

# ──────────────────────────────────────────────────────────────
# Oracle Database (thin mode — no Instant Client needed)
# ──────────────────────────────────────────────────────────────
DB_USER="QUOTEAPP"
DB_PASSWORD="<STRONG_DB_PASSWORD_MIN_12_CHARS>"
DB_CONNECTION_STRING="localhost:1521/XEPDB1"

# ──────────────────────────────────────────────────────────────
# Auth — JWT signing secret
# Must be ≥ 32 hex chars. Use:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ──────────────────────────────────────────────────────────────
JWT_SECRET="<GENERATE_96_HEX_CHARS_VIA_CRYPTO_RANDOMBYTES_48>"

# Refresh-token secret (SP1-H1+H2+H3 work) — separate from access-token
# secret so rotation of one doesn't blow up the other.
JWT_REFRESH_SECRET="<GENERATE_96_HEX_CHARS_SEPARATELY>"

# ──────────────────────────────────────────────────────────────
# SMTP (OTP delivery via Nodemailer + Gmail App Password)
# Generate Gmail App Password at https://myaccount.google.com/apppasswords
# ──────────────────────────────────────────────────────────────
SMTP_USER="<your.email@gmail.com>"
SMTP_PASS="<16-char-google-app-password>"

# ──────────────────────────────────────────────────────────────
# AI Chat (OpenRouter — used by QuotingModule AI assistant)
# Get a key at https://openrouter.ai/keys
# ──────────────────────────────────────────────────────────────
AI_PROVIDER="openrouter"
OPENROUTER_API_KEY="<sk-or-v1-…>"

# ──────────────────────────────────────────────────────────────
# Optional — pool tuning (defaults in db.js are fine for dev)
# ──────────────────────────────────────────────────────────────
# DB_POOL_MIN="2"
# DB_POOL_MAX="10"
# UV_THREADPOOL_SIZE="16"
